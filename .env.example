NEXT_PUBLIC_SITE_URL=https://sabandurali.com
NEXT_PUBLIC_FORMSPREE_FORM_ID=
NEXT_PUBLIC_FORMSPREE_CONTACT_FORM_ID=

# Public articles use static examples by default. Use "payload" only in
# .env.local for the local acceptance test; do not enable it in production.
ARTICLE_PUBLIC_SOURCE=static

# Public book reviews use static examples by default. Use "payload" only in
# .env.local for local acceptance tests; do not enable it in production.
BOOK_PUBLIC_SOURCE=static

# Public pages use the existing static Turkish home page by default. Use
# "payload" only in .env.local for local acceptance tests; do not enable it in
# production until persistent database and media storage are configured.
PAGE_PUBLIC_SOURCE=static

# Turkish Header, mobile menu and Footer use their current static links by
# default. Use "payload" only in .env.local for local acceptance tests; do not
# enable it in production until persistent database storage is configured.
NAVIGATION_PUBLIC_SOURCE=static

PAYLOAD_SECRET=
DATABASE_URL=file:./.data/payload.db
